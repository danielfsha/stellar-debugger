{
  "name": "stellar-debugger",
  "displayName": "stellar-debugger",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:stellar-debugger.runSorobanTests",
    "onCommand:stellar-debugger.runSorobanTestsCmd"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "stellar-debugger.runSorobanTests",
        "title": "Run Soroban Tests"
      },
      {
        "command": "stellar-debugger.runSorobanTestsCmd",
        "title": "Run Soroban Tests (Command Line)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@ai-sdk/mistral": "^3.0.30",
    "ai": "^6.0.156",
    "openai": "^6.34.0",
    "vectra": "^0.14.0"
  }
}
