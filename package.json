{
  "name": "stellar-debugger",
  "displayName": "stellar-debugger",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:stellar-debugger.runSorobanTests",
    "onCommand:stellar-debugger.runSorobanTestsCmd",
    "onCommand:extension.runUnitTests",
    "onCommand:extension.runPropertyTests",
    "onCommand:extension.runEndToEndTests",
    "onCommand:extension.runFuzzTests",
    "onCommand:extension.runSnapshotTests",
    "onCommand:extension.runAssertionInvariantTests",
    "onCommand:extension.runRuntimeCheckTests",
    "onCommand:extension.runDifferentialTests",
    "onCommand:extension.runFormalVerificationTests",
    "onCommand:extension.runTestDataManagementTests",
    "onCommand:extension.runMockIsolationTests",
    "onCommand:extension.runAllTests",
    "onCommand:extension.runTestOptions"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "stellar-debugger.runSorobanTests",
        "title": "Run Soroban Tests"
      },
      {
        "command": "stellar-debugger.runSorobanTestsCmd",
        "title": "Run Soroban Tests (Command Line)"
      },
      {
        "command": "extension.runUnitTests",
        "title": "Run Unit Tests"
      },
      {
        "command": "extension.runPropertyTests",
        "title": "Run Property Tests"
      },
      {
        "command": "extension.runEndToEndTests",
        "title": "Run End-to-End Tests"
      },
      {
        "command": "extension.runFuzzTests",
        "title": "Run Fuzz Tests"
      },
      {
        "command": "extension.runSnapshotTests",
        "title": "Run Snapshot Tests"
      },
      {
        "command": "extension.runAssertionInvariantTests",
        "title": "Run Assertion & Invariant Tests"
      },
      {
        "command": "extension.runRuntimeCheckTests",
        "title": "Run Runtime Check Tests"
      },
      {
        "command": "extension.runDifferentialTests",
        "title": "Run Differential Tests"
      },
      {
        "command": "extension.runFormalVerificationTests",
        "title": "Run Formal Verification Tests"
      },
      {
        "command": "extension.runTestDataManagementTests",
        "title": "Run Test Data Management Tests"
      },
      {
        "command": "extension.runMockIsolationTests",
        "title": "Run Mock & Isolation Tests"
      },
      {
        "command": "extension.runAllTests",
        "title": "Run All Tests"
      },
      {
        "command": "extension.runTestOptions",
        "title": "Run Test Options"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/node-fetch": "^2.6.13",
    "@types/vscode": "^1.115.0",
    "@types/whatwg-fetch": "^0.0.33",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@ai-sdk/mistral": "^3.0.30",
    "@huggingface/transformers": "^4.0.1",
    "@pinecone-database/pinecone": "^7.1.0",
    "ai": "^6.0.156",
    "openai": "^6.34.0"
  }
}
